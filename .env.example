# Pidate Environment Variables
# Copy this file to .env.local for local development

# ============================================
# REQUIRED: Pi Corpus Configuration
# ============================================

# URL to the pi corpus file (must support HTTP Range requests)
# This is used by the API to fetch small chunks of pi digits around date positions
#
# Option 1: Use MIT's server (default, simpler but slower)
PI_CORPUS_URL=https://stuff.mit.edu/afs/sipb/contrib/pi/pi-billion.txt
#
# Option 2: Use Vercel Blob (recommended for production - faster and more reliable)
# After uploading to Vercel Blob, replace with your blob URL:
# PI_CORPUS_URL=https://[your-blob-url].vercel-storage.com/pi-billion.txt

# ============================================
# OPTIONAL: Vercel Blob Storage Token
# ============================================

# Only required if you want automatic upload to Vercel Blob during build
# Get this token from: Vercel Dashboard → Storage → Blob → Tokens
# Create a token with "Read & Write" permissions
#
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xyz123

# ============================================
# DEPLOYMENT NOTES
# ============================================
#
# For Vercel deployment, set these environment variables in:
# Vercel Dashboard → Project Settings → Environment Variables
#
# Required for all environments:
# - PI_CORPUS_URL (Production, Preview, Development)
#
# Optional for automatic blob upload:
# - BLOB_READ_WRITE_TOKEN (Production, Preview)
#
# See VERCEL_DEPLOYMENT.md for detailed deployment instructions

# ============================================
# OPTIONAL: Analytics & Monitoring
# ============================================

# NEXT_PUBLIC_ANALYTICS_ID=
# SENTRY_DSN=
